# Hugging Face token (optional)
# Enables faster model downloads and removes rate-limit warnings.
# Get your free token at: https://huggingface.co/settings/tokens
#
# To use: copy this file to .env and uncomment the line below:
#   copy .env.example .env
#
# IMPORTANT: no quotes around the token value

HF_TOKEN=hf_your_token_here
